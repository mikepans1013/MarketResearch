# Server
PORT=5317

# Optional but recommended for private/internal deployments.
# If unset, the app runs without basic auth.
MARKET_APP_USERNAME=michael
MARKET_APP_PASSWORD=change-me

# Free Census API key from https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your-census-api-key

# Google Places/Geocoding API key for address autocomplete and ZIP fallback.
# Enable Places API and Geocoding API in Google Cloud Console.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Optional public URL for docs/deployment references.
APP_BASE_URL=https://your-subdomain.example.com
